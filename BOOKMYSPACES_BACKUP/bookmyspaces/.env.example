# ═══════════════════════════════════════════════════════════
# BOOKMYSPACES AI CRM — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────
# AI — CLAUDE (PRIMARY)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────
# AI — OPENAI (EMBEDDINGS + FALLBACK)
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─────────────────────────────────────────
# GOOGLE SHEETS SYNC
# ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=your-google-sheet-id

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─────────────────────────────────────────
# ADMIN (for dashboard login)
# ─────────────────────────────────────────
ADMIN_EMAIL=admin@bookmyspaces.in
ADMIN_PASSWORD=change-this-strong-password

# ─────────────────────────────────────────
# BUSINESS INFO (used in AI prompts)
# ─────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_WHATSAPP=9051459463
NEXT_PUBLIC_BUSINESS_PHONE=9830509991

# ─────────────────────────────────────────
# PHASE 2 — WHATSAPP (Wati.io)
# ─────────────────────────────────────────
# Get from: app.wati.io → Settings → API
# Business number awaiting Wati activation: 8274844343
# Leave blank until Wati account is approved and activated
WATI_BASE_URL=
WATI_API_TOKEN=

# Webhook verification
WATI_VERIFY_TOKEN=any-secret-string-you-choose
WATI_WEBHOOK_SECRET=optional-hmac-secret-for-security

# Alternative: Interakt (interakt.shop)
# INTERAKT_API_KEY=your-interakt-api-key
