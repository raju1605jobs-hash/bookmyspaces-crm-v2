# ═══════════════════════════════════════════════════════════
# BOOKMYSPACES AI CRM — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────
# AI — CLAUDE (PRIMARY)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────
# AI — OPENAI (EMBEDDINGS + FALLBACK)
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─────────────────────────────────────────
# GOOGLE SHEETS SYNC
# ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=your-google-sheet-id

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
# ISS-037: this is the ONLY base-URL variable the app reads (used for share links
# and post-logout redirects). A second, undocumented name — NEXT_PUBLIC_SITE_URL —
# used to be read in one file (auth/logout); that file has been updated to use
# this variable instead, so there is now exactly one name to set.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─────────────────────────────────────────
# BUSINESS INFO (used in AI prompts)
# ─────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_WHATSAPP=9051459463

# ─────────────────────────────────────────
# LIVE WHATSAPP INTEGRATION — Meta Cloud API (this is what the code actually
# uses for sending/receiving WhatsApp messages)
# ─────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-meta-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
# Must match whatever verify token you configure in the Meta App dashboard's
# webhook subscription (src/app/api/whatsapp/webhook/route.ts).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=any-secret-string-you-choose
# App Secret from the Meta App dashboard (Settings → Basic). Required for
# webhook signature verification (X-Hub-Signature-256) — until this is set,
# the webhook logs a warning but still accepts unsigned requests
# (see src/app/api/whatsapp/webhook/route.ts verifySignature()).
WHATSAPP_APP_SECRET=your-meta-app-secret

# ─────────────────────────────────────────
# LEGACY WHATSAPP INTEGRATION — Wati.io (only used for the /api/health status
# check and the transcription helper in src/lib/transcription.ts; the actual
# send/receive path above, Meta Cloud API, does not use these)
# ─────────────────────────────────────────
WATI_BASE_URL=
WATI_API_TOKEN=

# ─────────────────────────────────────────
# CRON AUTHENTICATION
# ─────────────────────────────────────────
# Bearer token compared against incoming Authorization header on cron routes
# (src/app/api/cron/followups/route.ts and src/app/api/cron/escalations/route.ts).
CRON_SECRET=generate-a-random-secret-and-set-the-same-value-in-vercel-cron-config

# ─────────────────────────────────────────
# REMOVED (ISS-029/ISS-038): the following variables used to be listed here but
# are never read anywhere in the code, so they've been removed to avoid confusion:
# ADMIN_EMAIL, ADMIN_PASSWORD (real login is handled by Supabase Auth instead),
# WATI_VERIFY_TOKEN, WATI_WEBHOOK_SECRET (no matching webhook code path exists),
# NEXT_PUBLIC_BUSINESS_PHONE (not referenced anywhere in src/).
# If you find you need any of these for a feature you're adding, that's fine —
# just document what it's for here when you add it back.
# ─────────────────────────────────────────
